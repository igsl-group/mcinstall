# =============================================================================
# MCdesk Backend Runtime Configuration
# =============================================================================
# Connection strings (DB/Redis/Kafka) are injected by docker-compose.yml
# so that this file can remain environment-agnostic.
# =============================================================================

# ---------------------------------------------------------------------------
# Application
# ---------------------------------------------------------------------------
SERVER_PORT=7080
TZ=Asia/Hong_Kong

# ---------------------------------------------------------------------------
# Database (PostgreSQL)
# ---------------------------------------------------------------------------
DB_SHOW_SQL=FALSE

# HikariCP connection pool
DB_MAX_POOLSIZE=20
DB_MIN_IDEL=10
DB_CONN_TIMEOUT=30000
DB_VALID_TIMEOUT=5000
DB_IDLE_TIMEOUT=600000
DB_MAX_LIFETIME=1800000
DB_KEEPALIVE_TIME=30000

# ---------------------------------------------------------------------------
# Redis / Redisson
# ---------------------------------------------------------------------------
# Mode: single or sentinel
REDIS_MODEL=single

# Redis thread pool
REDIS_THREADS=4
REDIS_NETTY_THREADS=8

# Redis connection timeouts
REDIS_CONN_IDELTIMEOUT=10000
REDIS_CONN_TIMEOUT=3000
REDIS_SUB_CONN_POOLSIZE=50

# Single-node settings
REDIS_SINGLE_CONN_MAXIDLE=8
REDIS_SINGLE_CONN_POOLSIZE=32

# Sentinel settings (only used when REDIS_MODEL=sentinel)
REDIS_SENTINEL_NODES=
REDIS_SENTINEL_MASTER_NAME=
REDIS_SENTINEL_MASTER_PWD=
REDIS_SENTINEL_READMODE=SLAVE
REDIS_SENTINEL_SUBMODE=MASTER
REDIS_SENTINEL_SSL=false
REDIS_SENTINEL_MASTER_CONN_MAXIDLE=32
REDIS_SENTINEL_MASTER_CONN_POOLSIZE=64
REDIS_SENTINEL_SLAVE_CONN_MAXIDLE=32
REDIS_SENTINEL_SLAVE_CONN_POOLSIZE=64

# ---------------------------------------------------------------------------
# Kafka
# ---------------------------------------------------------------------------
KAFKA_BATCH_SIZE_CONFIG=16384
KAFKA_MAX_POLL_RECORDS_CONFIG=500
KAFKA_FETCH_MAX_WAIT_MS_CONFIG=500
KAFKA_FETCH_MIN_BYTES_CONFIG=1024
KAFKA_CONCURRENCY=1
KAFKA_LINGER_MS_CONFIG=10
KAFKA_POLL_TIMEOUT=3000
KAFKA_SESSION_TIMEOUT_MS=30000
KAFKA_HEARTBEAT_INTERVAL_MS=10000
KAFKA_MAX_POLL_INTERVAL_MS=300000
KAFKA_REQUEST_TIMEOUT_MS=30000
KAFKA_RECONNECT_BACKOFF_MS=1000
KAFKA_RECONNECT_BACKOFF_MAX_MS=10000

# ---------------------------------------------------------------------------
# File Storage
# ---------------------------------------------------------------------------
FILE_PLATFORM=local-plus-1
FILE_SUFFIX=.min.png

FILE_LOCAL_ENABLE=true
FILE_LOCAL_ACCESS=true
FILE_LOCAL_NAME=local-plus-1
FILE_LOCAL_DOMAIN=/file/
FILE_LOCAL_BASE_PATH=WikiAttachment/
FILE_LOCAL_PATH_PATTERN=/file/**
FILE_LOCAL_STORAGE_PATH=/data/files/local/

FILE_SFTP_ENABLE=false
FILE_MINIO_ENABLE=false
FILE_S3_ENABLE=false
FILE_HW_ENABLE=false
FILE_ALI_ENABLE=false
FILE_TENC_ENABLE=false

FILE_BASE_LOCAL_PATH=/tmp
